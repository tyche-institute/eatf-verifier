#!/usr/bin/env node
// eatf-verify-ts — offline EATF .aep evidence-package verifier (TypeScript /
// @noble/post-quantum). Independent of the Node @eatf/cli verifier — uses
// the full hybrid RSA + ML-DSA-65 + RFC 3161 stack.
//
// Usage:
//   eatf-verify-ts <file.aep>        # human output (default)
//   eatf-verify-ts <file.aep> --json # JSON for scripting
//
// Exit codes:
//   0  valid
//   1  invalid
//   2  argv error / unreadable file

import { readFileSync, existsSync, statSync } from "node:fs";
import path from "node:path";
import process from "node:process";
import { pathToFileURL } from "node:url";

// --- locate the @eatf/verifier dist (installed or repo checkout) -----------

// eatf/bin/eatf-verify-ts → eatf/sdks/eatf-verifier-ts/dist/index.js (sibling)
const HERE = path.dirname(new URL(import.meta.url).pathname);
const REPO_DIST = process.env.EATF_VERIFIER_TS_DIST
  || path.join(HERE, "..", "sdks", "eatf-verifier-ts", "dist", "index.js");

const FALLBACK_DIST = path.join(process.env.HOME || "/tmp",
  "sdks/eatf-verifier-ts/dist/index.js");

async function loadVerify() {
  // 1. Try as an installed package
  try {
    const mod = await import("@eatf/verifier");
    return mod.verify;
  } catch (_) { /* fallthrough */ }

  // 2. Try the sibling dist (eatf/sdks/eatf-verifier-ts/dist)
  if (existsSync(REPO_DIST)) {
    const mod = await import(pathToFileURL(REPO_DIST).href);
    return mod.verify;
  }
  // 3. Fallback — repository-local build layout
  if (existsSync(FALLBACK_DIST)) {
    const mod = await import(pathToFileURL(FALLBACK_DIST).href);
    return mod.verify;
  }

  process.stderr.write(
    "[!] cannot locate @eatf/verifier — install with `npm i -g @eatf/verifier`\n" +
    "    or set EATF_VERIFIER_TS_DIST=/path/to/dist/index.js\n"
  );
  process.exit(2);
}

// --- ANSI ------------------------------------------------------------------

const COLOR = process.stdout.isTTY && !process.env.NO_COLOR;
const c = (code, t) => COLOR ? `\x1b[${code}m${t}\x1b[0m` : t;
const green  = (t) => c("32;1", t);
const red    = (t) => c("31;1", t);
const yellow = (t) => c("33;1", t);
const cyan   = (t) => c("36", t);
const dim    = (t) => c("2",  t);

// --- main ------------------------------------------------------------------

const argv = process.argv.slice(2);
const wantJson = argv.includes("--json");
const filePath = argv.find(a => !a.startsWith("--"));

if (!filePath) {
  process.stderr.write("usage: eatf-verify-ts <file.aep> [--json]\n");
  process.exit(2);
}
if (!existsSync(filePath) || !statSync(filePath).isFile()) {
  process.stderr.write(red(`[!] not found: ${filePath}\n`));
  process.exit(2);
}

const verify = await loadVerify();
const bytes = readFileSync(filePath);

let result;
try {
  result = await verify(bytes);
} catch (err) {
  process.stderr.write(red(`[!] verifier crash: ${err?.message || err}\n`));
  process.exit(1);
}

if (wantJson) {
  process.stdout.write(JSON.stringify(result, null, 2) + "\n");
  process.exit(result.valid ? 0 : 1);
}

const meta = result.metadata || {};
const tag  = result.valid ? green("[+] VALID ") : red("[!] INVALID");
process.stdout.write(`${tag}  ${filePath}\n`);

if (result.valid) {
  process.stdout.write(`    ${cyan("verifier:")}        @eatf/verifier (noble-PQC)\n`);
  process.stdout.write(`    ${cyan("pqc verified:")}    ${result.pqcValid ? green("yes") : yellow("n/a")}\n`);
  process.stdout.write(`    ${cyan("model:")}           ${green(meta.model || meta.signer || meta.engine || "?")}\n`);
  process.stdout.write(`    ${cyan("algorithm:")}       ${meta.algorithm || "?"}\n`);
  process.stdout.write(`    ${cyan("id:")}     ${meta.id || meta.response_id || "?"}\n`);
  process.stdout.write(`    ${cyan("uuid:")}            ${meta.uuid || "?"}\n`);
  process.stdout.write(`    ${cyan("policy_version:")}  ${meta.policy_version || "?"}\n`);
  process.stdout.write(`    ${cyan("signed_at:")}       ${meta.signed_at || meta.created_at || "?"}\n`);
  if (result.report && result.report.length) {
    process.stdout.write(dim("    --- verification report ---\n"));
    for (const line of result.report) {
      process.stdout.write(dim(`    · ${line}\n`));
    }
  }
} else {
  process.stdout.write(`    ${red("reason:")} ${result.failureReason || "unknown"}\n`);
  if (result.report) {
    for (const line of result.report) {
      process.stdout.write(dim(`    · ${line}\n`));
    }
  }
}

process.exit(result.valid ? 0 : 1);
