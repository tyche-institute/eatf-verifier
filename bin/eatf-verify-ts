#!/usr/bin/env node
// CommonJS launcher. Node treats extensionless scripts as CommonJS (which on
// some Node versions makes an ESM body fail silently), so the real
// implementation lives in eatf-verify-ts.mjs and is loaded via dynamic import.
"use strict";
const path = require("node:path");
const { pathToFileURL } = require("node:url");
import(pathToFileURL(path.join(__dirname, "eatf-verify-ts.mjs")).href).catch((err) => {
  console.error(err && err.stack ? err.stack : String(err));
  process.exit(2);
});
